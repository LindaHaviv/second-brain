# Copy to oracle/.env (which is gitignored) and fill in. The CHANGE_ME_* passwords below work for
# the LOCAL sandbox container so the quickstart runs — but they're PLACEHOLDERS: set your own
# before anything real. NEVER commit oracle/.env. See SECURITY.md.

# --- Anthropic (only for the agent / wiki; plain search + the MCP server don't need it) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LOCAL Oracle container (the quickstart) ---
ORACLE_PWD=CHANGE_ME_SysPwd1          # SYSTEM/SYS password (placeholder — local sandbox only)
APP_PWD=CHANGE_ME_AppPwd1              # CCC app-schema password (placeholder — local sandbox only)
DB_USER=CCC
DB_DSN=localhost:1521/FREEPDB1

# --- CLOUD: Oracle Autonomous DB (optional; see docs/CLOUD_MIGRATION.md) ---
# DB_USER=CCC
# DB_DSN=<tns alias, e.g. mybrain_high>
# APP_PWD=<cloud app-user password>
# DB_WALLET_DIR=/abs/path/to/unzipped/wallet
# DB_WALLET_PASSWORD=<wallet password>

# --- Sources (optional) ---
# NOTION_TOKEN=ntn_...
# IG_ACCESS_TOKEN=<long-lived Instagram token; scripts/instagram_token.py>   # keep secret
# IG_APP_SECRET=<Meta app secret; only needed to mint/refresh the token>
# BRAIN_INCLUDE_BUSINESS=1   # load private brand-deal financials into a LOCAL vault only (never cloud)

# --- Hosted MCP (optional; set these as your HOST'S SECRETS, not here — see docs/HOSTED_MCP.md) ---
# MCP_AUTH_TOKEN=<random; bearer fallback used only when AUTHKIT_DOMAIN is unset>
# AUTHKIT_DOMAIN=https://<slug>.authkit.app     # turns on WorkOS OAuth (for claude.ai/ChatGPT)
# MCP_BASE_URL=https://<your-app>.fly.dev
# ALLOWED_EMAILS=you@example.com                # ONLY these emails are authorized (fail-closed)
# ALLOWED_SUBS=user_...                         # WorkOS user id(s); AuthKit tokens carry sub, not email
# MCP_READONLY=1                                # drop the write tool — server can only READ the brain
# DB_POOL_MAX=4                                 # max pooled DB sessions per process (DB_POOL=0 disables)
