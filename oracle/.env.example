# Copy to oracle/.env (which is gitignored) and fill in. The demo passwords below are for the
# LOCAL container only — change them for anything real. NEVER commit oracle/.env. See SECURITY.md.

# --- Anthropic (only for the agent / wiki; plain search + the MCP server don't need it) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LOCAL Oracle container (the quickstart) ---
ORACLE_PWD=CHANGE_ME_SysPwd1          # SYSTEM/SYS password (local demo default)
APP_PWD=CHANGE_ME_AppPwd1              # CCC app-schema password (local demo default)
DB_USER=CCC
DB_DSN=localhost:1521/FREEPDB1

# --- CLOUD: Oracle Autonomous DB (optional; see docs/CLOUD_MIGRATION.md) ---
# DB_USER=CCC
# DB_DSN=<tns alias, e.g. mybrain_high>
# APP_PWD=<cloud app-user password>
# DB_WALLET_DIR=/abs/path/to/unzipped/wallet
# DB_WALLET_PASSWORD=<wallet password>

# --- Sources (optional) ---
# NOTION_TOKEN=ntn_...

# --- Hosted MCP (optional; set these as your HOST'S SECRETS, not here — see docs/HOSTED_MCP.md) ---
# MCP_AUTH_TOKEN=<random; bearer fallback used only when AUTHKIT_DOMAIN is unset>
# AUTHKIT_DOMAIN=https://<slug>.authkit.app     # turns on WorkOS OAuth (for claude.ai/ChatGPT)
# MCP_BASE_URL=https://<your-app>.fly.dev
# ALLOWED_EMAILS=you@example.com                # ONLY these emails are authorized (fail-closed)
